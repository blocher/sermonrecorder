SERMON_PROCESSOR=sermons.provider_processor.ProviderSermonProcessor
PUSH_ALERT_SENDER=sermons.push_alerts.LoggingPushAlertSender
SERMON_AUDIO_URL_MAX_AGE_SECONDS=14400
PEWCORDER_PUBLIC_WEB_URL=http://127.0.0.1:5173
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL="Pewcorder <share@pewcorder.app>"
DJANGO_EMAIL_HOST=localhost
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_EMAIL_USE_TLS=1
DJANGO_EMAIL_TIMEOUT_SECONDS=30
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe-diarize
